<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/recipeTextBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toStartOf="@+id/ivDeleteRecipe">

                <TextView
                    android:id="@+id/tvRecipeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mango Smoothie"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                    <TextView
                        android:id="@+id/tvRecipeCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smoothie"
                        android:textColor="@color/colorWhite"
                        android:textSize="11sp"
                        android:background="@color/colorPrimary"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"/>

                    <TextView
                        android:id="@+id/tvRecipeTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 10 min"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:id="@+id/tvRecipeCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 200 kcal"
                        android:textColor="@color/colorOrange"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/ivDeleteRecipe"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="@color/colorRed"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- Expandable ingredients preview -->
        <TextView
            android:id="@+id/tvRecipeIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ingredients loading..."
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewRecipe"
            style="@style/OutlineGreenButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="10dp"
            android:text="View Details"
            android:textSize="13sp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
