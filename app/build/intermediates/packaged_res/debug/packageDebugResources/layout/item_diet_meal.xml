<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Left color strip -->
        <View
            android:id="@+id/colorStrip"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:background="@color/colorPrimary"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/colorStrip"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMealName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oatmeal Breakfast"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvMealTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏰ 08:00 AM"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"/>

                <View android:layout_width="1dp" android:layout_height="14dp" android:background="@color/colorDivider" android:layout_marginLeft="8dp" android:layout_marginRight="8dp" android:layout_gravity="center_vertical"/>

                <TextView
                    android:id="@+id/tvMealCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 350 kcal"
                    android:textColor="@color/colorOrange"
                    android:textSize="13sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvMealNotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes here"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Delete Button -->
        <ImageView
            android:id="@+id/ivDeleteMeal"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/colorRed"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>

        <!-- Reminder badge -->
        <TextView
            android:id="@+id/tvReminderBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔"
            android:textSize="16sp"
            android:layout_above="@id/ivDeleteMeal"
            android:layout_alignParentEnd="true"
            android:visibility="gone"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
